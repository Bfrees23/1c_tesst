Функция ПолучитьОкладСотрудника(Сотрудник, ДатаЗначения) Экспорт
    Отбор = Новый Структура;
    Отбор.Вставить("Сотрудник", Сотрудник);

	Запись = РегистрыСведений.ОкладыСотрудников.ПолучитьПоследнее(ДатаЗначения, Отбор);

    Если Запись = Неопределено Тогда
        Возврат 0;     Иначе
        Возврат Запись.Оклад;
    КонецЕсли;

КонецФункции